{
    "name": "chapkit-app",
    "version": "1.0.0",
    "description": "Read-only DHIS2 explorer for CHAP model services (chapkit) via the chap-core route",
    "license": "BSD-3-Clause",
    "private": true,
    "packageManager": "pnpm@10.13.1",
    "scripts": {
        "build": "d2-app-scripts build",
        "start": "d2-app-scripts start --proxy http://localhost:8080 --proxyPort 7070",
        "start:local": "d2-app-scripts start --proxy http://localhost:8080 --proxyPort 7070",
        "start:play": "d2-app-scripts start --proxy https://play.im.dhis2.org/dev-2-42 --proxyPort 7070",
        "test": "d2-app-scripts test",
        "deploy": "d2-app-scripts deploy",
        "lint": "eslint && prettier -c .",
        "format": "prettier . -w"
    },
    "dependencies": {
        "@dhis2/app-runtime": "^3.17.0",
        "@dhis2/ui": "^10.16.3",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-router": "^7.17.0"
    },
    "devDependencies": {
        "@dhis2/cli-app-scripts": "12.11.2",
        "@dhis2/config-eslint": "^0.2.2",
        "@dhis2/config-prettier": "^0.2.2",
        "@eslint/compat": "^2.1.0",
        "@types/jest": "^30.0.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "eslint": "^10.5.0",
        "prettier": "^3.8.4",
        "typescript": "^6.0.3",
        "vite": "^8.0.16"
    }
}
